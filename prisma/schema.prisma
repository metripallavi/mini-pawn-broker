generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentMode {
  CASH
  BANK
}

enum VoucherType {
  LOAN
  PAYMENT
}

enum EntryType {
  DEBIT
  CREDIT
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  loans Loan[]
}

model Loan {
  id                   Int      @id @default(autoincrement())
  loanNumber           String?  @unique
  customerId           Int
  loanDate             DateTime
  loanAmount           Decimal  @db.Decimal(12, 2)
  interestRatePerMonth Decimal  @db.Decimal(5, 2)

  pledgedItemName String

  grossWeight        Decimal @db.Decimal(10, 3)
  stoneWeight        Decimal @db.Decimal(10, 3)
  estimatedItemValue Decimal @db.Decimal(12, 2)

  paymentMode PaymentMode

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  payments Payment[]
  vouchers Voucher[]
}

model Payment {
  id Int @id @default(autoincrement())

  loanId Int

  paymentDate DateTime

  amount Decimal @db.Decimal(12, 2)

  interestPaid Decimal @db.Decimal(12, 2)

  principalPaid Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  loan Loan @relation(fields: [loanId], references: [id])

  voucher Voucher?
}

model Voucher {
  id            Int      @id @default(autoincrement())
  voucherNumber String?  @unique
  voucherDate   DateTime
  voucherType   VoucherType

  loanId    Int?
  paymentId Int? @unique

  createdAt DateTime @default(now())

  loan    Loan?    @relation(fields: [loanId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  ledgerEntries LedgerEntry[]
}

model LedgerEntry {
  id Int @id @default(autoincrement())

  voucherId Int

  accountName String

  entryType EntryType

  amount Decimal @db.Decimal(12, 2)

  voucher Voucher @relation(fields: [voucherId], references: [id])
}